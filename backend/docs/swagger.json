            "get": {
                "description": "Возвращает статистику использования ресурсов",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "System"
                ],
                "summary": "Статистика использования",
                "responses": {
                    "200": {
                        "description": "Статистика использования",
                        "schema": {
                            "$ref": "#/definitions/models.APIResponse"
