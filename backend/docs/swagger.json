            "delete": {
                "description": "Удаляет существующий ресурс по его идентификатору",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Resources"
                ],
                "summary": "Удалить ресурс по ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID ресурса",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ресурс удален",
                        "schema": {
                            "$ref": "#/definitions/models.APIResponse"
                        }
                    }
                }
            },
            "patch": {
                "description": "Обновляет существующий ресурс по его идентификатору",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Resources"
                ],
                "summary": "Обновить ресурс по ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID ресурса",
                        "name": "id",
