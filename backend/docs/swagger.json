{
    "swagger": "2.0",
    "info": {
        "description": "Полное API для LocalVercel - локальной платформы для деплоя приложений\nПоддерживает проекты, деплои, логи, домены, переменные окружения,\nTelegram ботов, сборки, метрики, уведомления, Git интеграцию и шаблоны.\n\n## Аутентификация\nДля доступа к защищенным эндпоинтам используйте Bearer токен в заголовке:\n`Authorization: Bearer \u003cваш_токен\u003e`\n\n## WebSocket\nДля реального времени доступны WebSocket соединения:\n- `ws://localhost:8888/ws/deployments` - обновления деплоев\n- `ws://localhost:8888/ws/logs` - все логи\n- `ws://localhost:8888/ws/projects` - обновления проектов\n- `ws://localhost:8888/ws/logs/{deploymentId}` - логи конкретного деплоя",
        "title": "LocalVercel API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://www.localvercel.com/support",
            "email": "support@localvercel.com"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8888",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Возвращает статус сервиса и время работы",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "System"
                ],
                "summary": "Проверка здоровья",
                "responses": {
                    "200": {
                        "description": "Сервис работает",
                        "schema": {
                            "$ref": "#/definitions/models.APIResponse"
                        }
                    }
                }
            }
        },
        "/metrics/system": {
            "get": {
                "description": "Возвращает метрики системы (CPU, RAM, Disk)",
