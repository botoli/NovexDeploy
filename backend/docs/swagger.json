                    "application/json"
                ],
                "tags": [
                    "Metrics"
                ],
                "summary": "Системные метрики",
                "responses": {
                    "200": {
                        "description": "Системные метрики",
                        "schema": {
                            "$ref": "#/definitions/models.APIResponse"
                        }
                    }
                }
            }
        },
        "/search": {
            "get": {
                "description": "Ищет по проектам, деплоям, логам и ботам",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Search"
                ],
                "summary": "Поиск по всем ресурсам",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Поисковый запрос",
                        "name": "q",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Результаты поиска",
                        "schema": {
                            "$ref": "#/definitions/models.APIResponse"
                        }
                    }
                }
            }
        },
        "/status": {
            "get": {
                "description": "Возвращает информацию о версии и статусе сервиса",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "System"
                ],
                "summary": "Информация о сервисе",
                "responses": {
                    "200": {
                        "description": "Информация о сервисе",
